# Copy to .env.local and fill in.

# Mapbox public token, used for live dengue map tiles.
# Get one from https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase project settings, used for media URLs and community request storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI API key, used for Ask ORCA, suggestions, translation, TTS, and transcription.
OPENAI_API_KEY=
